{
  "name": "seo-command-center",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace apps/web",
    "dev:orchestrator": "npm run dev --workspace services/orchestrator",
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces"
  },
  "engines": {
    "node": ">=20.10.0"
  }
}
