SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# IMPORTANT: NEVER put service_role keys in NEXT_PUBLIC_* variables.

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Used to encrypt/decrypt user integration secrets. Any strong value is accepted.
CREDENTIAL_ENCRYPTION_KEY=YOUR_LONG_RANDOM_SECRET

# Optional global fallback only. Preferred source is per-user key in Settings.
ANTHROPIC_API_KEY=OPTIONAL_GLOBAL_ANTHROPIC_KEY
ANTHROPIC_MODEL=claude-3-7-sonnet-latest
ANTHROPIC_MAX_TOKENS=2500
ANTHROPIC_API_BASE_URL=https://api.anthropic.com

WEB_ORIGIN=http://localhost:3000
ORCHESTRATOR_PUBLIC_URL=https://YOUR_PUBLIC_ORCHESTRATOR_URL
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:4000
ORCHESTRATOR_INTERNAL_URL=http://localhost:4000

OPENCLAW_DAEMON_COMMAND=openclaw daemon --config openclaw.config.json
OPENCLAW_DISPATCH_COMMAND=openclaw dispatch --config openclaw.config.json
OPENCLAW_RUNTIME_DIR=openclaw-runtime

SKILLS_CLI_BIN=npx
SKILLS_SEARCH_SUBCOMMAND=skills find
SKILLS_INSTALL_SUBCOMMAND=skills add --yes --global
SKILLS_COMMAND_TIMEOUT_MS=120000

AUTOPILOT_POLL_MS=15000
AUTOPILOT_CYCLE_INTERVAL_MS=1800000
AUTOPILOT_BATCH_SIZE=3

# Optional global fallback only. Preferred source is per-user key in Settings.
TELEGRAM_BOT_TOKEN=OPTIONAL_GLOBAL_TELEGRAM_TOKEN
TELEGRAM_WEBHOOK_SECRET=OPTIONAL_GLOBAL_TELEGRAM_WEBHOOK_SECRET
